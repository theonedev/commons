export async function prepareChromeTrace(
  directory: string,
  name: string,
  nonce = randomUUID().slice(0, 8),
) {
  return `${directory}/${name}-${nonce}`
}

export function projectForSession<T extends { id?: string; worktree: string }>(
  session: Session,
  projects: T[],
) {
  return projects[0]
}

