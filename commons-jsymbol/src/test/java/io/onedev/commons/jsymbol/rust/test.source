type PrivateAlias = String;
pub type PublicAlias = String;

pub mod service {
	pub struct User {
		pub id: u64,
		name: String,
	}

	pub enum State {
		Ready,
		Failed(String),
		Custom {
			code: u16,
		},
	}

	pub trait Repository {
		fn get(&self, id: u64) -> Option<User>;
		fn save(&mut self, user: User) {
		}
	}

	impl User {
		pub fn new(id: u64, name: String) -> Self {
			let local_value = id;
			Self { id: local_value, name }
		}

		fn private_name(&self) -> &str {
			&self.name
		}
	}

	impl<T: Display> From<T> for User {
		fn from(value: T) -> Self {
			Self::new(0, value.to_string())
		}
	}
}

